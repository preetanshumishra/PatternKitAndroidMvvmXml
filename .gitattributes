# Normalize line endings; let Git auto-detect text vs binary
* text=auto eol=lf

# Scripts must keep their platform line endings
gradlew      text eol=lf
*.sh         text eol=lf
gradlew.bat  text eol=crlf
*.bat        text eol=crlf

# Treat known binaries as binary
*.jar      binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ttf      binary
*.otf      binary
*.keystore binary
*.jks      binary
